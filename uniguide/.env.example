# Gemini API (embeddings always use this, regardless of LLM_PROVIDER below).
# Comma-separated, any number of keys — tried in order as fallbacks if one is
# invalid or its free-tier quota is exhausted, for both embeddings and
# (when LLM_PROVIDER=groq/gemini) agent calls. e.g. key1,key2,key3
GEMINI_API_KEYS=

# Embeddings: "gemini" (default, needs GEMINI_API_KEY) or "local" (sentence-transformers, offline)
EMBEDDING_PROVIDER=gemini

# Which LLM backs the agents: "groq" (default, free tier, use for the demo), "gemini",
# or "claude". "groq" falls back through every GROQ_API_KEYS key below, then every
# GEMINI_API_KEYS key above, if a call fails (invalid key, exhausted quota, etc.)
# before erroring out. "gemini" falls back through every GEMINI_API_KEYS key.
LLM_PROVIDER=groq
# Comma-separated, any number of keys — tried in order as fallbacks. e.g. key1,key2,key3
GROQ_API_KEYS=
GROQ_MODEL=llama-3.3-70b-versatile

# Google Calendar — either a service account key JSON (no browser/OAuth flow;
# share the target calendar with this key's client_email, "Make changes to
# events") or an OAuth client-secret JSON (needs a one-time interactive
# browser consent, then caches a refreshable token next to this file).
# tools/calendar_tool.py detects which kind this is automatically. Set
# GOOGLE_CALENDAR_ID to the target calendar's id (not "primary" — for a
# service account, "primary" is its own invisible calendar, not a human's).
# Sync only ever runs when a user explicitly triggers it (dashboard's "Sync
# to Calendar" button) — it's never called automatically.
GOOGLE_SERVICE_ACCOUNT_FILE=./data/service-account.json
GOOGLE_CALENDAR_ID=

# Storage
DATABASE_URL=sqlite:///./data/uniguide.db
CHROMA_PERSIST_DIR=./data/chroma

# Program requirements
DEGREE_TOTAL_ECTS=120
WEAK_GRADE_THRESHOLD=2.7
